{
    "integration_metadata": {
        "target_system": "GST Service",
        "api_version": "v1.0"
    },
    "security_config": {
        "auth_type": "Bearer",
        "credential_vault_reference": "ENV.GST_SERVICE_KEY",
        "target_url": "http://localhost:8004/mock-gst/validate"
    },
    "schema_transformation_rules": {
        "request_mapping": {
            "gstin": "$.business_data.gstin",
            "business_name": "$.business_data.businessName",
            "pan_number": "$.business_data.panNumber"
        },
        "response_logic": "if $.gst_status != 'ACTIVE' then return 'FLAG_MANUAL_REVIEW' else return 'APPROVE'"
    }
}